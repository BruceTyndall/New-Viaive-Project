{
  "$schema": "viaive.components.v1",
  "version": "1.0.0",
  "updated": "2026-05-14",
  "components": [
    {
      "name": "Nav",
      "file": "src/app/components/Nav.tsx",
      "purpose": "Top global navigation. Anchors brand, primary desks, concierge CTA.",
      "props": { "transparent": "boolean — true on hero", "active": "string — current route slug" },
      "payloadGlobal": "navigation",
      "payloadFields": ["brand", "primaryLinks[]", "ctaLabel", "ctaHref"],
      "desktop": "Fixed top, paper background, 2px bottom border on scroll.",
      "mobile": "Collapses to hamburger; sheet overlay slides from right.",
      "states": ["resting", "scrolled", "open(mobile)"],
      "a11y": ["nav landmark", "aria-expanded on menu toggle", "Esc closes sheet"],
      "routes": ["all"]
    },
    {
      "name": "Hero",
      "file": "src/app/components/Hero.tsx",
      "purpose": "Page-opening editorial lockup with primary + secondary CTA.",
      "props": { "eyebrow": "string", "headline": "string", "italicHeadline": "string", "lede": "string", "primaryCta": "{label,href}", "secondaryCta": "{label,href}", "image": "MediaRef" },
      "payloadBlock": "HeroBlock",
      "payloadFields": ["eyebrow", "headline", "italicHeadline", "lede", "primaryCta{label,href}", "secondaryCta{label,href}", "image"],
      "desktop": "Two-column 1fr:520px, image right.",
      "mobile": "Stacks; image collapses to 4:5 aspect below copy.",
      "states": ["resting"],
      "a11y": ["h1 single instance", "image alt required"],
      "routes": ["/", "/desks/*", "/destinations/*"]
    },
    {
      "name": "TrustBar",
      "file": "src/app/components/TrustBar.tsx",
      "purpose": "Press/partner logo strip below hero. Establishes editorial credibility.",
      "props": { "items": "TrustItem[] {label, href?}" },
      "payloadBlock": "TrustBarBlock",
      "payloadFields": ["items[]{label,logo,href}"],
      "desktop": "Single row, 6–8 items, paper background.",
      "mobile": "Horizontal scroll with snap.",
      "states": ["resting"],
      "a11y": ["role=list", "logo alt = publication name"],
      "routes": ["/", "/concierge"]
    },
    {
      "name": "IntentRouter",
      "file": "src/app/components/IntentRouter.tsx",
      "purpose": "Four-card decision router: Hotel / Family / Somatic / Unsure.",
      "props": { "cards": "IntentCard[]" },
      "payloadBlock": "IntentRouterBlock",
      "payloadFields": ["cards[]{title,blurb,href,eyebrow}"],
      "desktop": "4-up grid.",
      "mobile": "2x2 grid, then 1-up below 480px.",
      "states": ["resting", "hover(press)"],
      "a11y": ["each card is a single <a> with descriptive text"],
      "routes": ["/", "/start-planning"]
    },
    {
      "name": "Desks",
      "file": "src/app/components/Desks.tsx",
      "purpose": "Service-desk surface: Hotel, Family, Safari, Concierge, Asia Intelligence.",
      "props": { "desks": "Desk[]" },
      "payloadCollection": "desks",
      "payloadFields": ["slug", "name", "eyebrow", "lede", "specialties[]", "leadTime", "priceFloor", "ctaHref"],
      "desktop": "5-column rail with dividers.",
      "mobile": "Vertical stack with 2px stone rules.",
      "states": ["resting", "hover"],
      "a11y": ["each desk h3", "list semantics"],
      "routes": ["/", "/desks/*"]
    },
    {
      "name": "Atlas",
      "file": "src/app/components/Atlas.tsx",
      "purpose": "Regional hub map / index. Phase-1 placeholder for the 7 regional hubs.",
      "props": { "regions": "Region[]" },
      "payloadCollection": "regions",
      "payloadFields": ["slug", "name", "lead", "destinations[]"],
      "desktop": "3-column grid of region cards.",
      "mobile": "Stack with sticky region label.",
      "states": ["resting"],
      "a11y": ["h2 + nested h3 per region"],
      "routes": ["/", "/atlas"]
    },
    {
      "name": "DestinationsRail",
      "file": "src/app/components/DestinationsRail.tsx",
      "purpose": "Dark stone rail of highest-revenue destinations, anchor-scrolls to guides.",
      "props": { "destinations": "DestinationConfig[]" },
      "payloadCollection": "destinations",
      "payloadFields": ["slug", "city", "region", "geoAnswer", "bestMonths", "hotels[]"],
      "desktop": "3-up grid, dark.",
      "mobile": "1-up stack.",
      "states": ["resting", "hover(gold offset)"],
      "a11y": ["each tile is <a href='#destination-{slug}'>"],
      "routes": ["/"]
    },
    {
      "name": "DestinationGuide",
      "file": "src/app/components/DestinationGuide.tsx",
      "purpose": "Long-form destination editorial with sticky Stay22 map + audited hotel list.",
      "props": { "config": "DestinationConfig" },
      "payloadCollection": "destinations",
      "payloadFields": ["slug","city","country","lat","lng","bestMonths","leadTime","readMinutes","heroEyebrow","h1","h1Italic","geoAnswer","hotels[]","watch2026[]","sections[]","ctaEyebrow","ctaHeadline","ctaBody","conciergeIntent"],
      "desktop": "1fr + 360px sidebar, sidebar sticky top-28.",
      "mobile": "Stack; sidebar moves below body; map aspect 4:5.",
      "states": ["resting"],
      "a11y": ["TouristDestination schema", "iframe title", "rel=sponsored on affiliate anchors"],
      "routes": ["/", "/destinations/:slug"]
    },
    {
      "name": "Standard",
      "file": "src/app/components/Standard.tsx",
      "purpose": "Editorial audit standard: 7 criteria Viaive applies to every property.",
      "props": { "criteria": "Criterion[]" },
      "payloadGlobal": "viaiveStandard",
      "payloadFields": ["intro", "criteria[]{title,body,icon}"],
      "desktop": "Two-column with offset numbering.",
      "mobile": "Stack with sticky number column.",
      "states": ["resting"],
      "a11y": ["ordered list semantics"],
      "routes": ["/", "/about/standard"]
    },
    {
      "name": "Editorial",
      "file": "src/app/components/Editorial.tsx",
      "purpose": "Long-form editorial preview rail (Field Notes, Letters).",
      "props": { "posts": "Post[]" },
      "payloadCollection": "posts",
      "payloadFields": ["slug","title","dek","author","publishedAt","cover","readMinutes"],
      "desktop": "3-up cards with eyebrow + dek.",
      "mobile": "1-up with horizontal swipe.",
      "states": ["resting", "hover"],
      "a11y": ["article landmark per card", "time element for date"],
      "routes": ["/", "/journal"]
    },
    {
      "name": "StayModule",
      "file": "src/app/components/StayModule.tsx",
      "purpose": "Stay22 search surface: destination/dates/guests/tier with affiliate disclosure.",
      "props": { "defaultDestination": "string?" },
      "payloadBlock": "StayModuleBlock",
      "payloadFields": ["title", "lede", "defaultDestination", "disclosureText"],
      "desktop": "Inline 4-field row + CTA.",
      "mobile": "Stack, full-bleed inputs.",
      "states": ["resting", "loading", "error"],
      "a11y": ["each input labeled", "disclosure read with aria-describedby"],
      "routes": ["/", "/destinations/*", "/best/*"]
    },
    {
      "name": "Proof",
      "file": "src/app/components/Proof.tsx",
      "purpose": "Testimonial + outcome strip. Lifetime metrics + 2 quotes.",
      "props": { "metrics": "Metric[]", "quotes": "Quote[]" },
      "payloadGlobal": "proof",
      "payloadFields": ["metrics[]{value,label}", "quotes[]{body,attribution,role}"],
      "desktop": "Metrics row + 2-col quotes below.",
      "mobile": "Metrics stack; quotes carousel.",
      "states": ["resting"],
      "a11y": ["blockquote + cite"],
      "routes": ["/", "/concierge"]
    },
    {
      "name": "Brief",
      "file": "src/app/components/Brief.tsx",
      "purpose": "Concierge brief intake form preview / entry.",
      "props": { "intent": "string?" },
      "payloadBlock": "BriefBlock",
      "payloadFields": ["title", "lede", "fields[]", "submitLabel"],
      "desktop": "Two-column with form left, reassurance right.",
      "mobile": "Stack.",
      "states": ["resting", "submitting", "submitted", "error"],
      "a11y": ["all inputs labeled", "error live region"],
      "routes": ["/", "/concierge", "/start-planning"]
    },
    {
      "name": "EmailCapture",
      "file": "src/app/components/EmailCapture.tsx",
      "purpose": "The Quiet Letter — inline newsletter signup.",
      "props": {},
      "payloadGlobal": "newsletter",
      "payloadFields": ["title", "lede", "placeholder", "consentText", "successText"],
      "desktop": "Centered, 640px max.",
      "mobile": "Full-bleed.",
      "states": ["resting", "submitting", "success", "error"],
      "a11y": ["email input type=email + autocomplete=email"],
      "routes": ["/", "/journal", "/destinations/*"]
    },
    {
      "name": "FAQ",
      "file": "src/app/components/FAQ.tsx",
      "purpose": "Accordion FAQ with FAQPage schema.org JSON-LD.",
      "props": { "items": "FAQItem[]" },
      "payloadBlock": "FAQBlock",
      "payloadFields": ["title", "items[]{question,answer}"],
      "desktop": "Single column, 70ch.",
      "mobile": "Same; touch targets ≥44px.",
      "states": ["closed", "open"],
      "a11y": ["aria-expanded", "button per row", "FAQPage JSON-LD emitted"],
      "routes": ["/", "/concierge", "/destinations/*"]
    },
    {
      "name": "Footer",
      "file": "src/app/components/Footer.tsx",
      "purpose": "Site footer: sitemap, legal, affiliate disclosure, social.",
      "props": {},
      "payloadGlobal": "footer",
      "payloadFields": ["columns[]{title,links[]}", "legalLinks[]", "disclosure", "socialLinks[]"],
      "desktop": "4 columns + legal row.",
      "mobile": "Accordion sections.",
      "states": ["resting"],
      "a11y": ["contentinfo landmark"],
      "routes": ["all"]
    },
    {
      "name": "NovaExitIntent",
      "file": "src/app/components/NovaExitIntent.tsx",
      "purpose": "Stay22 Nova exit-intent capture modal.",
      "props": {},
      "payloadGlobal": "novaExitIntent",
      "payloadFields": ["headline","italicHeadline","body","ctaLabel","ctaHref","dismissLabel","minDwellSec"],
      "desktop": "Center modal, 12px stone shadow.",
      "mobile": "Bottom sheet variant.",
      "states": ["hidden", "shown", "dismissed"],
      "a11y": ["role=dialog", "aria-modal", "focus trap", "Esc dismisses"],
      "routes": ["/", "/destinations/*", "/best/*"]
    },
    {
      "name": "ImageWithFallback",
      "file": "src/app/components/figma/ImageWithFallback.tsx",
      "purpose": "Image element with fallback handling; required for all <img> uses.",
      "props": { "src": "string", "alt": "string", "className": "string?" },
      "payloadField": "MediaRef → R2 URL",
      "desktop": "Inherits parent.",
      "mobile": "Inherits parent.",
      "states": ["loading", "loaded", "error→fallback"],
      "a11y": ["alt required"],
      "routes": ["all"]
    }
  ]
}
